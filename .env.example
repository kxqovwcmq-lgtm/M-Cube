# Supported provider values:
# openai | claude | anthropic | gemini | kimi | minimax | qwen | doubao | deepseek | glm
LLM_PROVIDER=
LLM_MODEL=
LLM_VISION_MODEL=
LLM_BASE_URL=

# OpenAI-specific fallback fields used by current router/doc parser paths.
OPENAI_MODEL=gpt-4o
OPENAI_VISION_MODEL=gpt-4o
OPENAI_BASE_URL=

# Provider API Keys
# OpenAI
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=
# ANTHROPIC_BASE_URL=

# Google Gemini (current code reads GEMINI_API_KEY)
GEMINI_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Qwen / DashScope
DASHSCOPE_API_KEY=

# GLM / Zhipu
ZHIPUAI_API_KEY=

# Kimi / Moonshot
MOONSHOT_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# Doubao / Volcengine Ark
ARK_API_KEY=


# API Security / Runtime. If set, every API call must pass matching X-API-Key.
APP_API_KEY=

SESSION_TTL_DAYS=30
UPLOAD_TTL_HOURS=24
UPLOAD_ROOT_DIR=.runtime/uploads

CORS_ALLOW_ORIGINS=http://127.0.0.1:5173,http://localhost:5173,http://127.0.0.1:1420,http://localhost:1420,tauri://localhost

UPLOAD_MAX_SIZE_BYTES=20971520
UPLOAD_MAX_EMBEDDED_IMAGES=40
UPLOAD_MAX_IMAGE_BYTES=5242880
UPLOAD_MAX_TOTAL_IMAGE_BYTES=26214400
UPLOAD_MAX_IMAGE_PIXELS=16000000
UPLOAD_MIN_PRIMARY_IMAGE_SIDE=120
UPLOAD_MIN_PRIMARY_IMAGE_AREA=30000
UPLOAD_MAX_IMAGES_PER_PDF_PAGE=4
UPLOAD_PDF_TEXT_MIN_CHARS=50
UPLOAD_RENDERED_PDF_DPI=144
# 1=enable LLM OCR fallback for scanned PDFs, 0=disable
UPLOAD_LLM_OCR_FALLBACK=1

LLM_MAX_VISION_IMAGES=8
LLM_MAX_VISION_IMAGE_BYTES=4194304
LLM_MAX_OUTPUT_TOKENS=4096
LLM_HTTP_TIMEOUT_SECONDS=240
LLM_HTTP_CONNECT_TIMEOUT_SECONDS=20
