FROM node:20-alpine

WORKDIR /app/frontend

# Install deps first to leverage cache.
COPY frontend/package*.json /app/frontend/
RUN npm install

# Copy frontend source.
COPY frontend /app/frontend

EXPOSE 1420

# Avoid Windows-specific npm script ("set ... && vite") inside Linux container.
CMD ["npx", "vite", "--host", "0.0.0.0", "--port", "1420", "--strictPort"]
